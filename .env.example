# No API key is required for the default Codex-bridge + local embedding path.
FUNGI_EMBEDDING_BACKEND=sentence_transformers
FUNGI_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
FUNGI_GENERATOR_BACKEND=codex_bridge
FUNGI_CHROMA_DIR=data/chroma
FUNGI_UPLOAD_DIR=data/uploads
FUNGI_SOURCE_RAW_DIR=data/sources/raw
FUNGI_INDEX_DIR=data/index
FUNGI_OUTPUT_DIR=outputs
FUNGI_RETRIEVAL_TOP_K=6
FUNGI_ENABLE_CODEX_CLI=false

# Optional comparison/tracing integrations.
# OPENAI_API_KEY=
# LANGSMITH_API_KEY=
